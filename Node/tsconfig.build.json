{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./"
    },
    "include": [
        "index.ts",
        "components/**/*.ts",
        "services/**/*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "bin",
        "apps"
    ]
}
